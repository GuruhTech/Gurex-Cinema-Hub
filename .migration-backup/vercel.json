{
  "installCommand": "pnpm install",
  "buildCommand": "pnpm --filter @workspace/gurex-movies run build",
  "outputDirectory": "artifacts/gurex-movies/dist/public",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "env": {
    "BASE_PATH": "/"
  }
}
